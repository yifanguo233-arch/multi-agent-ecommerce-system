# LLM Configuration
ECOM_LLM_API_KEY=
ECOM_LLM_BASE_URL=https://api.minimaxi.com/v1
ECOM_LLM_MODEL=MiniMax-M2.7
ECOM_PLANNER_USE_LLM=false
ECOM_PLANNER_LLM_TIMEOUT_SECONDS=30
ECOM_AGENT_TIMEOUT_PLANNER=35
ECOM_PLANNER_LLM_MAX_TOKENS=768

# Redis
ECOM_REDIS_URL=redis://localhost:6379/0

# Milvus
ECOM_MILVUS_HOST=localhost
ECOM_MILVUS_PORT=19530

# Database
ECOM_DATABASE_URL=sqlite:///./ecommerce.db
ECOM_PRODUCT_AUTO_SEED=true
ECOM_PRODUCT_SEED_COUNT=240
ECOM_PRODUCT_CATALOG_CACHE_LIMIT=500
# Postgres example:
# ECOM_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ecommerce

# A/B Testing
ECOM_AB_TEST_ENABLED=true

# LangGraph checkpoint / replay
ECOM_CHECKPOINT_BACKEND=sqlite
ECOM_CHECKPOINT_SQLITE_PATH=./ecommerce_checkpoints.db
